# Momentus AI — Environment Variables
# Copy to .env and fill in your values

# Anthropic / Claude API (required for analysis & generation)
GEO_ANTHROPIC_API_KEY=

# Peec API (legacy REST — optional, use CSV import as fallback)
GEO_PEEC_API_KEY=
GEO_PEEC_API_BASE_URL=https://api.peec.ai/v1

# Peec MCP (preferred — live data, sentiment, competitor movement)
# Bearer token issued by Peec for your account.
GEO_PEEC_MCP_URL=https://api.peec.ai/mcp
GEO_PEEC_MCP_TOKEN=
# 0 = manual sync only; set to e.g. 60 to auto-sync every 60 min per workspace
GEO_PEEC_MCP_AUTO_SYNC_MINUTES=0

# WordPress CMS (optional)
GEO_WORDPRESS_URL=
GEO_WORDPRESS_USERNAME=
GEO_WORDPRESS_APP_PASSWORD=

# Webflow CMS (optional)
GEO_WEBFLOW_API_TOKEN=
GEO_WEBFLOW_COLLECTION_ID=

# Security
GEO_API_SECRET_KEY=change-this-to-a-random-string

# Server
GEO_HOST=0.0.0.0
GEO_PORT=8100
GEO_DEBUG=false
GEO_CORS_ORIGINS=*

# Cost limits (USD)
GEO_CLAUDE_DAILY_COST_LIMIT=50.0
GEO_CLAUDE_MONTHLY_COST_LIMIT=500.0
