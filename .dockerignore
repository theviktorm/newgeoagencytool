# Keep the Docker build context small and reproducible. The frontend bundle is
# built inside the image (STAGE 1), so host-side build artifacts are excluded.
frontend/node_modules
frontend/dist
frontend/.npm-cache

# Python / env / VCS noise
.venv
__pycache__/
*.pyc
.git
.pytest_cache
.DS_Store
*.log
.env
.env.*
!.env.example
